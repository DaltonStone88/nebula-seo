// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core App Models ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile
  agencyName    String?
  phone         String?
  timezone      String?   @default("America/Chicago")
  hasSeenOnboarding Boolean @default(false)

  // Plan
  plan          Plan      @default(ORBIT)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  // Relations
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
}

model Business {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Basic info
  name        String
  address     String?
  city        String?
  state       String?
  zip         String?
  phone       String?
  website     String?
  category    String?

  // Google
  gbpAccountId   String?
  gbpLocationId  String?
  placeId        String?
  googleAccessToken  String? @db.Text
  googleRefreshToken String? @db.Text
  googleTokenExpiry  DateTime?

  // Location
  lat         Float?
  lng         Float?

  // SEO Settings
  targetCities   String[]
  targetKeywords String[]
  gridSize       String?  @default("7x7")
  gridSpacing    String?  @default("medium")

  // Stats
  avgRating   Float?   @default(0)
  totalReviews Int?    @default(0)
  avgRank     Float?

  // Status
  status      BusinessStatus @default(ACTIVE)

  // Billing (per-location subscription)
  stripeSubscriptionId  String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd     Boolean  @default(false)
  discountUsed          Boolean  @default(false)  // one-time 10% off offer
  pauseUsed             Boolean  @default(false)  // one-time 30-day pause offer

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews     Review[]
  posts       GBPPost[]
  rankAudits  RankAudit[]
  automations Automation[]
  automationPosts AutomationPost[]
  offers      BusinessOffer[]
  events      BusinessEvent[]
  updates     BusinessUpdate[]
  images      BusinessImage[]
}

model Review {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  googleReviewId String? @unique
  author      String?
  rating      Int
  text        String?  @db.Text
  response    String?  @db.Text
  respondedAt DateTime?
  publishedAt DateTime?

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model GBPPost {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  
  content     String     @db.Text
  imageUrl    String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  googlePostId String?

  businessId  String
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model RankAudit {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  keyword     String
  gridData    Json     // stores the heatmap grid
  avgRank     Float
  top3Percent Float
  isBaseline  Boolean  @default(false)
  gridSize    String?  @default("7x7")

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  type        AutomationType
  status      AutomationStatus @default(SUCCESS)
  description String
  details     Json?

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─── Automation Content Models ───────────────────────────────────────────────

model AutomationPost {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Post content
  content       String   @db.Text
  postType      String   // WHATS_NEW, OFFER, EVENT
  keyword       String?
  city          String?
  imageUrl      String?
  imageIndex    Int?     // which image slot was used

  // Scheduling
  scheduledFor  DateTime?
  publishedAt   DateTime?
  googlePostId  String?

  // Approval
  status        AutomationPostStatus @default(PENDING)
  approvedAt    DateTime?

  // For offers
  offerTitle    String?
  offerCode     String?
  offerUrl      String?
  offerTerms    String?
  offerStart    DateTime?
  offerEnd      DateTime?

  // For events
  eventTitle    String?
  eventStart    DateTime?
  eventEnd      DateTime?

  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessOffer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  title       String
  description String?  @db.Text
  couponCode  String?
  redeemUrl   String?
  terms       String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean  @default(true)

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  title       String
  description String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean  @default(true)

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessUpdate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  title       String?
  content     String   @db.Text
  active      Boolean  @default(true)

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessImage {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  url         String
  filename    String?
  size        Int?
  sortOrder   Int      @default(0)

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  ORBIT
  NEBULA
  GALAXY
}

enum BusinessStatus {
  ACTIVE
  PAUSED
  PENDING
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AutomationType {
  GBP_POST
  REVIEW_RESPONSE
  REPORT_SENT
  FAQ_GENERATED
  CITATION_SYNCED
  CONTENT_PUBLISHED
}

enum AutomationStatus {
  SUCCESS
  FAILED
  PENDING
}

enum AutomationPostStatus {
  PENDING
  APPROVED
  PUBLISHED
  FAILED
  REJECTED
}
