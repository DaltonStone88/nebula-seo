// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core App Models ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile
  agencyName    String?
  phone         String?
  timezone      String?   @default("America/Chicago")

  // Plan
  plan          Plan      @default(ORBIT)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  // Relations
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
}

model Business {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Basic info
  name        String
  address     String?
  city        String?
  state       String?
  zip         String?
  phone       String?
  website     String?
  category    String?

  // Google
  gbpAccountId   String?
  gbpLocationId  String?
  placeId        String?
  googleAccessToken  String? @db.Text
  googleRefreshToken String? @db.Text
  googleTokenExpiry  DateTime?

  // Location
  lat         Float?
  lng         Float?

  // SEO Settings
  targetCities   String[]
  targetKeywords String[]
  gridSize       String?  @default("7x7")
  gridSpacing    String?  @default("medium")

  // Keyword change tracking (per keyword slot, stored as JSON: [{keyword, changedAt, changedFrom}])
  keywordHistory Json?

  // Stats
  avgRating   Float?   @default(0)
  totalReviews Int?    @default(0)
  avgRank     Float?

  // Status
  status      BusinessStatus @default(ACTIVE)

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews     Review[]
  posts       GBPPost[]
  rankAudits  RankAudit[]
  automations Automation[]
}

model Review {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  googleReviewId String? @unique
  author      String?
  rating      Int
  text        String?  @db.Text
  response    String?  @db.Text
  respondedAt DateTime?
  publishedAt DateTime?

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model GBPPost {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  
  content     String     @db.Text
  imageUrl    String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  googlePostId String?

  businessId  String
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model RankAudit {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  keyword     String
  gridData    Json     // stores the heatmap grid
  avgRank     Float
  top3Percent Float
  isBaseline  Boolean  @default(false)
  gridSize    String?  @default("7x7")

  // Keyword change tracking
  keywordChangedAt   DateTime? // set when this audit starts a new keyword after a change
  keywordChangedFrom String?   // the old keyword that was replaced
  daysTracked        Int?      // how many days since keyword was set (for PDF note)

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  type        AutomationType
  status      AutomationStatus @default(SUCCESS)
  description String
  details     Json?

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  ORBIT
  NEBULA
  GALAXY
}

enum BusinessStatus {
  ACTIVE
  PAUSED
  PENDING
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AutomationType {
  GBP_POST
  REVIEW_RESPONSE
  REPORT_SENT
  FAQ_GENERATED
  CITATION_SYNCED
  CONTENT_PUBLISHED
}

enum AutomationStatus {
  SUCCESS
  FAILED
  PENDING
}
