{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/report/pdf/route.js": {
      "maxDuration": 60
    },
    "src/app/api/automation/generate/route.js": {
      "maxDuration": 300
    },
    "src/app/api/cron/automation/route.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/automation",
      "schedule": "0 6 * * *"
    }
  ]
}
